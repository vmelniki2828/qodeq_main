# Куда приходят письма с заявок (обязательно)
NOTIFY_EMAIL=you@example.com

# От кого (если не задано — берётся NOTIFY_EMAIL)
# SMTP_FROM="Qodeq <noreply@yourdomain.com>"

# SMTP провайдера (обязательно SMTP_HOST)
# Примеры: smtp.gmail.com, smtp.mailgun.org, smtp.eu.mailgun.org, smtp.yandex.ru
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Префикс темы письма (необязательно)
# MAIL_SUBJECT_PREFIX=[Сайт] Заявка

PORT=3001
