# Отключаем генерацию source maps (убирает предупреждения)
GENERATE_SOURCEMAP=false
# Отключаем ESLint для продакшена (опционально)
DISABLE_ESLINT_PLUGIN=false
# Подавляем предупреждения webpack
SKIP_PREFLIGHT_CHECK=true

# POST JSON на ваш бэкенд: { contact, consent, timestamp, page, product? }
# Пример: https://api.yourdomain.com/contact-leads или /api/contact-leads за прокси
# REACT_APP_CONTACT_API_URL=
